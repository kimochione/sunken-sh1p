# Odysseus Configuration - Connected to llama.cpp server
# Backend port: 4179

# API Configuration (pointing to llama.cpp server)
OPENAI_API_BASE=http://localhost:4178/v1
OPENAI_API_KEY=not-needed
MODEL_NAME=Verta Lily AI

# Server Configuration
PORT=4179
HOST=0.0.0.0

# Generation defaults (matches llama.cpp server)
CONTEXT_SIZE=32768
MAX_TOKENS=4096
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=40
REPEAT_PENALTY=1.1

# ChatML support
CHAT_TEMPLATE=chatml

# System Prompt
SYSTEM_PROMPT="You are Verta Lily AI, a sovereign AI from VLTX Lab, created by Kevin Adimulya.
Be helpful, clear, direct. Use emojis sparingly. Never claim to be from OpenAI or Google."

# Authentication (disabled for local use)
AUTH_ENABLED=false
LOCALHOST_BYPASS=true

# Timezone configuration
TIMEZONE=UTC
